# Required — LLM Configuration
API_KEY=not-needed-for-local-development
BASE_URL=http://localhost:8321/v1
MODEL_ID=ollama/llama3.1:8b

# Downstream Agent URLs — comma-separated list of A2A peer base URLs.
# Agent cards are fetched automatically from each peer's /.well-known/agent-card.json
# at startup to discover capabilities, tool descriptions, and routing rules.
AGENT_URLS=

# Deployment
CONTAINER_IMAGE=
NAMESPACE=
